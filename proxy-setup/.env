# Puertos del stack
ACESTREAM_HTTP_PORT=6878
ACESTREAM_API_PORT=62062
PROXY_PORT=8080
HTTPACEPROXY_PORT=8888

# Comportamiento del proxy
SESSION_TIMEOUT=600
MAX_CONNECTIONS=10
MAX_CONCURRENT_CHANNELS=3

# Plugins habilitados (separados por comas)
ENABLED_PLUGINS=newera,elcano,stat

# Mostrar listas de streams en la interfaz web
SHOW_STREAM_LISTS=false